# Copy this file to .env if you want shell-based local configuration.
# Spring Boot does not read .env automatically; load it with:
#   set -a
#   source .env
#   set +a
#   ./mvnw spring-boot:run

# Moshi backend WebSocket that Spring relays browser audio to.
MOSHI_WS_URL=ws://localhost:8998/api/chat

# Let Spring auto-start Moshi MLX when the app starts.
MOSHI_AUTO_START=true

# Let Spring create the venv and install moshi_mlx if it is missing.
MOSHI_AUTO_INSTALL=true

# Python executable that has moshi_mlx installed.
# Recommended setup:
#   python3.12 -m venv ~/.venvs/moshi-mlx
#   ~/.venvs/moshi-mlx/bin/python -m pip install -U pip moshi_mlx
MOSHI_PYTHON=${HOME}/.venvs/moshi-mlx/bin/python

# Python used only to create the venv when MOSHI_PYTHON does not exist.
MOSHI_BOOTSTRAP_PYTHON=/opt/homebrew/bin/python3.12

# Moshi local server bind settings.
MOSHI_HOST=0.0.0.0
MOSHI_PORT=8998

# MLX quantization. Use 4 for the smallest local model; 8 needs more memory.
MOSHI_QUANTIZED=4
